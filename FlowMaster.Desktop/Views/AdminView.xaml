<UserControl x:Class="FlowMaster.Desktop.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="750">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#002c5f"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Background" Value="#002c5f"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Background" Value="#c0392b"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="NormalButton" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Command="{Binding GoBackCommand}" Content="← 돌아가기"
                        Padding="8,5" Background="#e4dcd3" BorderThickness="1" BorderBrush="#ccc"/>
                <TextBlock Text="시스템 관리" FontSize="20" FontWeight="Bold"
                           Foreground="#002c5f" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 최초 실행 안내 배너 -->
            <Border Visibility="{Binding IsFirstRun, Converter={StaticResource BoolToVis}}"
                    Background="#fff3cd" BorderBrush="#ffc107" BorderThickness="1"
                    Padding="12,8" CornerRadius="4" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠️" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="최초 실행: 등록된 사용자가 없습니다."
                                   FontWeight="SemiBold" Foreground="#856404"/>
                        <TextBlock Text="아래 '사용자 관리' 탭에서 관리자 계정을 먼저 추가하세요. AD 계정을 입력 후 '저장'하면 됩니다."
                                   Foreground="#856404" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 탭 -->
        <TabControl Grid.Row="1">

            <!-- ═══ 사용자 관리 탭 ═══ -->
            <TabItem Header="사용자 관리">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="285"/>
                    </Grid.ColumnDefinitions>

                    <!-- 사용자 목록 -->
                    <DockPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock DockPanel.Dock="Top" Text="등록된 사용자" Style="{StaticResource HeaderText}"/>
                        <DataGrid ItemsSource="{Binding Users}"
                                  SelectedItem="{Binding SelectedUser}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" CanUserResizeRows="False"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="AD 계정" Binding="{Binding AdAccount}"    Width="110"/>
                                <DataGridTextColumn Header="이름"    Binding="{Binding Name}"         Width="100"/>
                                <DataGridTextColumn Header="이메일"  Binding="{Binding Email}"        Width="*"/>
                                <DataGridTextColumn Header="그룹"    Binding="{Binding GroupsDisplay}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <!-- 사용자 입력 폼 -->
                    <Border Grid.Column="1" Background="#f5f5f5" BorderBrush="#ddd"
                            BorderThickness="1" Padding="12" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="{Binding UserFormTitle}" Style="{StaticResource HeaderText}" Margin="0,0,0,10"/>

                            <!-- AD 계정 (자동완성 드롭다운) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="AD 계정" Style="{StaticResource FormLabel}"/>
                                <Grid>
                                    <TextBox x:Name="adAccountTextBox"
                                             Text="{Binding FormAdAccount, UpdateSourceTrigger=PropertyChanged}"
                                             Width="150"/>
                                    <!-- 로딩 표시 (검색 중) -->
                                    <TextBlock Text="검색 중..." FontSize="10" Foreground="#888"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" IsHitTestVisible="False"
                                               Visibility="{Binding IsAdSearchLoading, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </StackPanel>

                            <!-- 자동완성 안내 텍스트 -->
                            <TextBlock Text="2글자 이상 입력 시 자동 검색됩니다"
                                       FontSize="10" Foreground="#999" Margin="70,0,0,6"/>

                            <!-- AD 검색 결과 Popup (코드-비하인드에서 PlacementTarget 설정) -->
                            <Popup x:Name="adSearchPopup"
                                   Placement="Bottom"
                                   StaysOpen="True"
                                   AllowsTransparency="False">
                                <Border Background="White" BorderBrush="#aaa" BorderThickness="1"
                                        Effect="{x:Null}">
                                    <ListBox x:Name="adSearchList"
                                             Width="220" MaxHeight="200"
                                             BorderThickness="0"
                                             ItemsSource="{Binding AdSearchResults}"
                                             SelectionChanged="AdSearchList_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="6,4"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding AdAccount}"
                                                               FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11" Foreground="#555"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>

                            <!-- 이름 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="이름" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormDisplayName, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                            </StackPanel>

                            <!-- 이메일 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="이메일" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                            </StackPanel>

                            <!-- 그룹 선택 (동적 체크박스) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="그룹" Style="{StaticResource FormLabel}"/>
                                <ScrollViewer MaxHeight="90" VerticalScrollBarVisibility="Auto" Width="160">
                                    <ItemsControl ItemsSource="{Binding FormGroupSelections}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding GroupName}"
                                                          IsChecked="{Binding IsSelected}"
                                                          Margin="0,0,0,3" VerticalContentAlignment="Center"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>

                            <!-- MPI/GDI 참여자 그룹 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="참여자" Style="{StaticResource FormLabel}"/>
                                <StackPanel>
                                    <CheckBox Content="MPI" IsChecked="{Binding FormIsMpi}"
                                              Margin="0,0,0,4" VerticalContentAlignment="Center"/>
                                    <CheckBox Content="GDI" IsChecked="{Binding FormIsGdi}"
                                              VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 버튼 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="초기화" Command="{Binding NewUserFormCommand}"
                                        Style="{StaticResource NormalButton}"/>
                                <Button Content="저장" Command="{Binding SaveUserCommand}"
                                        Style="{StaticResource PrimaryButton}"/>
                                <Button Content="삭제" Command="{Binding DeleteUserCommand}"
                                        Style="{StaticResource DangerButton}"/>
                            </StackPanel>

                            <!-- 상태 메시지 -->
                            <TextBlock Text="{Binding UserStatusMessage}" Foreground="#555"
                                       FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ 그룹 관리 탭 ═══ -->
            <TabItem Header="그룹 관리">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="180"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 그룹 목록 + 그룹 폼 -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <!-- 그룹 목록 -->
                        <DockPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock DockPanel.Dock="Top" Text="그룹 목록" Style="{StaticResource HeaderText}"/>
                            <DataGrid ItemsSource="{Binding Groups}"
                                      SelectedItem="{Binding SelectedGroup}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" CanUserResizeRows="False"
                                      GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="그룹명" Binding="{Binding DisplayName}"  Width="150"/>
                                    <DataGridTextColumn Header="설명"   Binding="{Binding Description}"  Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>

                        <!-- 그룹 폼 -->
                        <Border Grid.Column="1" Background="#f5f5f5" BorderBrush="#ddd"
                                BorderThickness="1" Padding="12" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="{Binding GroupFormTitle}" Style="{StaticResource HeaderText}" Margin="0,0,0,8"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="그룹명" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding FormGroupName, UpdateSourceTrigger=PropertyChanged}" Width="145"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="설명" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding FormGroupDescription, UpdateSourceTrigger=PropertyChanged}"
                                             Width="145" Height="40" TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="초기화" Command="{Binding NewGroupFormCommand}"
                                            Style="{StaticResource NormalButton}"/>
                                    <Button Content="저장" Command="{Binding SaveGroupCommand}"
                                            Style="{StaticResource PrimaryButton}"/>
                                    <Button Content="삭제" Command="{Binding DeleteGroupCommand}"
                                            IsEnabled="{Binding CanDeleteSelectedGroup}"
                                            Style="{StaticResource DangerButton}"/>
                                </StackPanel>

                                <TextBlock Text="{Binding GroupStatusMessage}" Foreground="#555"
                                           FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 구분선 -->
                    <Separator Grid.Row="1" Margin="0,6"/>

                    <!-- 그룹 멤버 관리 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 현재 멤버 (다중 선택 가능) -->
                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top" Style="{StaticResource HeaderText}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="현재 멤버 ({0})">
                                        <Binding Path="SelectedGroup.GroupName" FallbackValue="그룹 선택"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <ListBox x:Name="groupMembersList"
                                     ItemsSource="{Binding GroupMembers}"
                                     SelectionMode="Extended"
                                     SelectionChanged="GroupMembersList_SelectionChanged"
                                     DisplayMemberPath="Name"/>
                        </DockPanel>

                        <!-- 추가 / 제거 버튼 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                            <Button Content="← 추가" Command="{Binding AddGroupMemberCommand}"
                                    Padding="8,6" Style="{StaticResource PrimaryButton}" Margin="4,0,4,4"/>
                            <Button Content="제거 →" Command="{Binding RemoveGroupMemberCommand}"
                                    Padding="8,6" Style="{StaticResource DangerButton}" Margin="4,0,4,0"/>
                        </StackPanel>

                        <!-- 추가 가능 사용자 (다중 선택 가능) -->
                        <DockPanel Grid.Column="2">
                            <TextBlock DockPanel.Dock="Top" Text="추가 가능한 사용자"
                                       Style="{StaticResource HeaderText}"/>
                            <ListBox x:Name="nonGroupMembersList"
                                     ItemsSource="{Binding NonGroupMembers}"
                                     SelectionMode="Extended"
                                     SelectionChanged="NonGroupMembersList_SelectionChanged"
                                     DisplayMemberPath="Name"/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- 참여자 그룹 탭 -->
            <TabItem Header="참여자 그룹">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 그룹 선택 토글 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="그룹:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <Button Content="MPI" Command="{Binding SelectMpiGroupCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"/>
                        <Button Content="GDI" Command="{Binding SelectGdiGroupCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                        <TextBlock Text="{Binding SelectedParticipantGroup, StringFormat='  선택됨: {0}'}"
                                   VerticalAlignment="Center" Foreground="#666" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- 사용자 검색 -->
                    <TextBlock Grid.Row="1" Text="멤버 추가 (AD 검색)" Style="{StaticResource HeaderText}"/>
                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <TextBox Text="{Binding ParticipantGroupSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" BorderBrush="#ccc" BorderThickness="1"/>
                        <!-- 검색 결과 드롭다운 -->
                        <ListBox ItemsSource="{Binding ParticipantGroupSearchResults}"
                                 Visibility="{Binding IsParticipantGroupSearchVisible, Converter={StaticResource BoolToVis}}"
                                 MaxHeight="150" VerticalAlignment="Top" Margin="0,30,0,0"
                                 Panel.ZIndex="10" BorderBrush="#002c5f" BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}"
                                            Command="{Binding DataContext.AddToParticipantGroupCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            BorderThickness="0" Background="Transparent"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="6,4" Cursor="Hand"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- 현재 그룹 멤버 목록 -->
                    <TextBlock Grid.Row="3" Text="그룹 멤버" Style="{StaticResource HeaderText}"
                               VerticalAlignment="Top" Margin="0,0,0,4"/>
                    <ListBox Grid.Row="3" Margin="0,24,0,0"
                             ItemsSource="{Binding ParticipantGroupMembers}"
                             SelectedItem="{Binding SelectedParticipantGroupMember}"
                             DisplayMemberPath="Name"
                             BorderBrush="#ddd" BorderThickness="1"/>

                    <!-- 하단 버튼 + 상태 -->
                    <DockPanel Grid.Row="4" Margin="0,8,0,0">
                        <TextBlock Text="{Binding ParticipantGroupStatusMessage}"
                                   VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                        <Button Content="선택 멤버 제거"
                                Command="{Binding RemoveFromParticipantGroupCommand}"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ═══ 체크리스트 템플릿 탭 ═══ -->
            <TabItem Header="체크리스트 템플릿">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 왼쪽: 템플릿 목록 -->
                    <DockPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock DockPanel.Dock="Top" Text="템플릿 목록" Style="{StaticResource HeaderText}"/>
                        <!-- 버튼 영역 -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                            <Button Content="+ 새 템플릿"
                                    Command="{Binding NewTemplateCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                            <Button Content="↺ 새로고침"
                                    Command="{Binding RefreshTemplatesCommand}"
                                    Style="{StaticResource NormalButton}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding ChecklistTemplates}"
                                 SelectedItem="{Binding SelectedTemplate}"
                                 BorderBrush="#ddd" BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,2">
                                        <TextBlock Text="{Binding TemplateCode}" FontWeight="SemiBold" Foreground="#002c5f"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11" TextWrapping="Wrap"/>
                                        <TextBlock FontSize="10" Foreground="#888">
                                            <Run Text="v"/><Run Text="{Binding Version}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- 오른쪽: 템플릿 편집 폼 -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>  <!-- 설명란 미리보기 (조건부) -->
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 이름/설명/Description 포함 여부 -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <!-- 폼 타이틀: 새 템플릿 작성 / 템플릿 수정 -->
                            <TextBlock Text="{Binding TemplateFormTitle}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#002c5f" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="이름" Style="{StaticResource FormLabel}" Width="50"/>
                                <TextBox Text="{Binding TemplateFormCode, UpdateSourceTrigger=PropertyChanged}"
                                         Width="100" Padding="4,3"/>
                                <TextBlock Text="(예: BA3)" Foreground="#888" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="설명" Style="{StaticResource FormLabel}" Width="50"/>
                                <TextBox Text="{Binding TemplateFormName, UpdateSourceTrigger=PropertyChanged}"
                                         Width="300" Padding="4,3"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding TemplateHasDescription}"
                                          Content="문서 작성 시 설명(Description) 입력란 포함"
                                          VerticalAlignment="Center" Margin="50,0,0,0"
                                          ToolTip="체크 시 테스트 결과 입력 화면에서 설명 텍스트 입력란이 표시됩니다."/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 항목 헤더 + 추가/가져오기 버튼 -->
                        <DockPanel Grid.Row="1" Margin="0,0,0,4">
                            <TextBlock Text="체크리스트 항목" Style="{StaticResource HeaderText}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <!-- 기존 템플릿 편집 시에만 표시 -->
                                <Button Content="📤 현재 내보내기" Command="{Binding ExportCurrentCsvCommand}"
                                        Visibility="{Binding IsTemplateEditMode, Converter={StaticResource BoolToVis}}"
                                        Style="{StaticResource NormalButton}" ToolTip="현재 템플릿 항목을 CSV로 내보내기 (Excel에서 수정 후 재가져오기 가능)"/>
                                <!-- 새 템플릿 작성 시에만 표시 -->
                                <Button Content="📥 샘플 내보내기" Command="{Binding ExportSampleCsvCommand}"
                                        Visibility="{Binding IsNewTemplate, Converter={StaticResource BoolToVis}}"
                                        Style="{StaticResource NormalButton}" ToolTip="작성 양식용 샘플 CSV 파일 내보내기 (Excel로 열기)"/>
                                <Button Content="📋 클립보드 붙여넣기" Command="{Binding ImportFromClipboardCommand}"
                                        Style="{StaticResource NormalButton}" ToolTip="엑셀에서 셀 선택 후 Ctrl+C → 이 버튼 클릭 (보안툴 암호화 우회)"/>
                                <Button Content="🗑 선택 삭제" Command="{Binding RemoveSelectedTemplateItemsCommand}"
                                        Style="{StaticResource NormalButton}" ToolTip="선택된 행을 모두 삭제 (Ctrl+클릭 또는 Shift+클릭으로 복수 선택)"/>
                                <Button Content="▶ 메인 추가" Command="{Binding AddMainTemplateItemCommand}"
                                        Style="{StaticResource NormalButton}" ToolTip="메인 항목 추가 (예: 1, 2, 3)"/>
                                <Button Content="└ 서브 추가" Command="{Binding AddSubTemplateItemCommand}"
                                        Style="{StaticResource NormalButton}" ToolTip="서브 항목 추가 (예: 1.1, 1.2, 2.1)"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- 항목 DataGrid - 7열: No. / 확인항목(멀티라인) / 산출물 / 평가 / 비고(공통) / 비고(MPI) / 비고(GDI) -->
                        <DataGrid Grid.Row="2"
                                  x:Name="TemplateItemsGrid"
                                  ItemsSource="{Binding TemplateItems}"
                                  SelectionMode="Extended"
                                  SelectionChanged="TemplateItemsGrid_SelectionChanged"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  EnableRowVirtualization="False">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                            <Setter Property="Background" Value="#dde4f0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <!-- No. -->
                                <DataGridTextColumn Header="No." Binding="{Binding RowNo, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="65" MinWidth="50"/>

                                <!-- 확인항목: 멀티라인 TextBox -->
                                <DataGridTemplateColumn Header="확인항목" Width="*" MinWidth="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CheckItem}" TextWrapping="Wrap"
                                                       Padding="4,3" VerticalAlignment="Top"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding CheckItem, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap" AcceptsReturn="True"
                                                     MinHeight="52" MaxHeight="200"
                                                     VerticalScrollBarVisibility="Auto"
                                                     Padding="4,3"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <!-- 산출물 -->
                                <DataGridTemplateColumn Header="산출물(기본값)" Width="140" MinWidth="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding OutputContent}" TextWrapping="Wrap"
                                                       Padding="4,3" VerticalAlignment="Top"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding OutputContent, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap" AcceptsReturn="True"
                                                     MinHeight="36" MaxHeight="200"
                                                     VerticalScrollBarVisibility="Auto"
                                                     Padding="4,3"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <!-- 평가(기본값): ComboBox -->
                                <DataGridTemplateColumn Header="평가(기본)" Width="80" MinWidth="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding EvaluationCode}"
                                                       HorizontalAlignment="Center" Padding="4,3"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedItem="{Binding EvaluationCode, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding DataContext.EvalOptions,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      IsEditable="False"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <!-- 비고(공통): MPI/GDI 구분 없이 적용 -->
                                <DataGridTextColumn Header="비고(공통)"
                                                    Binding="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="110" MinWidth="70"/>

                                <!-- 비고(MPI): 값이 있으면 MPI 문서에서 비고(공통) 대신 사용 -->
                                <DataGridTextColumn Header="비고(MPI)"
                                                    Binding="{Binding RemarksMpi, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="110" MinWidth="70"/>

                                <!-- 비고(GDI): 값이 있으면 GDI 문서에서 비고(공통) 대신 사용 -->
                                <DataGridTextColumn Header="비고(GDI)"
                                                    Binding="{Binding RemarksGdi, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="110" MinWidth="70"/>

                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 설명란 미리보기: HasDescription 체크 시만 DataGrid 아래에 표시 -->
                        <Border Grid.Row="3"
                                Visibility="{Binding TemplateHasDescription, Converter={StaticResource BoolToVis}}"
                                Background="#f0f5ff" BorderBrush="#7b9fd4" BorderThickness="1"
                                CornerRadius="4" Padding="10,6" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="미리보기 — 설명 입력란" FontSize="11" Foreground="#5a7abf" Margin="0,0,0,4"/>
                                <TextBox IsReadOnly="True"
                                         Text="(테스트 결과 입력 시 작성자가 이 영역에 설명을 입력합니다)"
                                         Foreground="#999" FontStyle="Italic" TextWrapping="Wrap"
                                         Background="Transparent" BorderBrush="#aac0e8"
                                         Padding="4,4" MinHeight="40"/>
                            </StackPanel>
                        </Border>

                        <!-- 저장/삭제 버튼 -->
                        <DockPanel Grid.Row="4" Margin="0,8,0,0">
                            <TextBlock Text="{Binding TemplateStatusMessage}"
                                       VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#666"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TemplateStatusIsError}" Value="True">
                                                <Setter Property="Foreground" Value="#c0392b"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <Button Content="↩ 롤백" Command="{Binding RevertTemplateCommand}"
                                        Style="{StaticResource NormalButton}"
                                        ToolTip="마지막 저장 상태로 되돌립니다. (새 템플릿이면 작성 내용을 초기화합니다.)"/>
                                <Button Content="저장" Command="{Binding SaveTemplateCommand}"
                                        Style="{StaticResource PrimaryButton}"/>
                                <Button Content="삭제" Command="{Binding DeleteTemplateCommand}"
                                        Style="{StaticResource DangerButton}"
                                        Visibility="{Binding IsTemplateEditMode, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- 버전/CSV 안내 -->
                        <StackPanel Grid.Row="5" Margin="0,6,0,0">
                            <TextBlock FontSize="11" Foreground="#888" TextWrapping="Wrap"
                                       Text="저장 시 버전 변경 여부를 묻습니다. 새 버전으로 저장하면 기존 버전은 보존됩니다."/>
                            <TextBlock FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,2,0,0"
                                       Text="클립보드 열 순서: No. / 확인항목 / 산출물 / 평가 / 비고(공통) / 비고(MPI) / 비고(GDI) — 탭/세미콜론/쉼표 구분자 자동 감지. 비고(MPI)/비고(GDI)는 값이 있을 때만 해당 InjType 문서에 적용됩니다."/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

        <!-- ── 탭 5: 산출물 경로 설정 ── -->
        <TabItem Header="산출물 경로 설정">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- BA1 섹션 -->
                <TextBlock Grid.Row="0" Text="BA1 산출물 버튼 경로" Style="{StaticResource HeaderText}" Margin="0,0,0,6"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Ba1OutputConfigs}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          BorderBrush="#ddd" BorderThickness="1"
                          CanUserSortColumns="False" SelectionMode="Single"
                          Margin="0,0,0,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="버튼명" Binding="{Binding ButtonName}" Width="160" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="4,3"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="실행방식" Binding="{Binding LaunchType}" Width="90" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="4,3"/>
                                    <Setter Property="Foreground" Value="#555"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="경로" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path}" VerticalAlignment="Center"
                                               Padding="4,3" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Path}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="4,3" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- BA2 섹션 -->
                <TextBlock Grid.Row="2" Text="BA2 산출물 버튼 경로" Style="{StaticResource HeaderText}" Margin="0,0,0,6"/>
                <DataGrid Grid.Row="3" ItemsSource="{Binding Ba2OutputConfigs}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          BorderBrush="#ddd" BorderThickness="1"
                          CanUserSortColumns="False" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="버튼명" Binding="{Binding ButtonName}" Width="160" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="4,3"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="실행방식" Binding="{Binding LaunchType}" Width="90" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="4,3"/>
                                    <Setter Property="Foreground" Value="#555"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="경로" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path}" VerticalAlignment="Center"
                                               Padding="4,3" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Path}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="4,3" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 저장 버튼 -->
                <DockPanel Grid.Row="4" Margin="0,10,0,0">
                    <TextBlock Text="경로를 수정한 후 저장 버튼을 클릭하세요."
                               FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                    <Button Content="저장" Command="{Binding SaveOutputConfigsCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                </DockPanel>
            </Grid>
        </TabItem>

        </TabControl>
    </Grid>
</UserControl>
