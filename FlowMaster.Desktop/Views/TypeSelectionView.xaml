<UserControl x:Class="FlowMaster.Desktop.Views.TypeSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:FlowMaster.Desktop"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="600">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NullToCollapsedConverter x:Key="NullToCollapsed"/>
        <Style x:Key="TypeCardButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#ddd"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="30,40"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f0f7ff"/>
                                <Setter Property="BorderBrush" Value="#002c5f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="#F6F3F2">
        <Border Background="White" CornerRadius="12" Margin="40" Padding="40"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="5"/>
            </Border.Effect>
            
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="📋 새 테스트 문서 생성" 
                           FontSize="24" FontWeight="Bold" Foreground="#002c5f"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>
                
                <TextBlock Text="테스트 유형을 선택하세요:" 
                           FontSize="16" Foreground="#555"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>
                
                <!-- Type Selection Cards (동적 로드) -->
                <ItemsControl ItemsSource="{Binding AvailableTemplates}" HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource TypeCardButton}"
                                    Command="{Binding DataContext.SelectTypeCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding TemplateCode}">
                                <StackPanel>
                                    <TextBlock Text="{Binding TemplateCode}" FontSize="32" FontWeight="Bold"
                                               Foreground="#002c5f" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#555"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"
                                               MaxWidth="160" TextWrapping="Wrap" TextAlignment="Center"/>
                                    <TextBlock FontSize="11" Foreground="#888" HorizontalAlignment="Center"
                                               Margin="0,6,0,0">
                                        <Run Text="v"/><Run Text="{Binding Version}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <!-- Clone Section -->
                <Border Background="#f8f8f8" CornerRadius="8" Margin="0,30,0,0" Padding="15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="🔄 기존 문서에서 복제:" VerticalAlignment="Center" Margin="0,0,10,0"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="(제목, 작성자, DocId로 검색)" Foreground="#999" FontSize="11" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- 선택된 문서 표시 -->
                        <Border Background="#e8f4fd" CornerRadius="4" Padding="8,4" Margin="0,0,0,6"
                                Visibility="{Binding SelectedCloneSource, Converter={StaticResource NullToCollapsed}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="📄" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding SelectedCloneText}" FontWeight="SemiBold" 
                                           Foreground="#002c5f" VerticalAlignment="Center"/>
                                <Button Content="✕" Command="{Binding ClearCloneSelectionCommand}"
                                        Margin="8,0,0,0" Padding="4,0" FontSize="10"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Foreground="#999" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 검색 입력 -->
                        <TextBox Text="{Binding CloneSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="400" HorizontalAlignment="Center" Padding="8,6"
                                 FontSize="13">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="  🔍 문서 제목 또는 작성자명으로 검색..." 
                                                                       Foreground="#aaa" FontSize="13" Margin="6,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        
                        <!-- 검색 결과 드롭다운 -->
                        <Border Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="0,0,4,4"
                                Width="400" HorizontalAlignment="Center" MaxHeight="200"
                                Visibility="{Binding IsCloneSearchVisible, Converter={StaticResource BoolToVis}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CloneSearchResults}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectCloneDocumentCommand, 
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    HorizontalContentAlignment="Stretch"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Padding="10,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DocId, StringFormat='[{0}]'}" 
                                                               Foreground="#999" Width="50" FontSize="12"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" 
                                                               Foreground="#333" TextTrimming="CharacterEllipsis"
                                                               MaxWidth="240"/>
                                                    <TextBlock Text="{Binding WriterName}" Foreground="#666" 
                                                               Margin="10,0,0,0" FontSize="12"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- DB Connection -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="📂 외부 DB 연결" Command="{Binding ConnectDbCommand}"
                            Padding="15,8" Margin="5"/>
                    <TextBlock Text="{Binding DbConnectionStatus}" VerticalAlignment="Center" 
                               Foreground="#666" FontSize="12"/>
                </StackPanel>
                
                <!-- Cancel Button -->
                <Button Content="취소" Command="{Binding CancelCommand}"
                        HorizontalAlignment="Center" Margin="0,30,0,0"
                        Padding="30,10" Background="#e4dcd3" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
