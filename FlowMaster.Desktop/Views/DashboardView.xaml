<UserControl x:Class="FlowMaster.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:FlowMaster.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Row 0: Pending Header + Grid (결재자만 표시) -->
            <RowDefinition Height="Auto" /> <!-- Row 1: My Docs Header + 선택삭제 버튼 -->
            <RowDefinition Height="Auto" /> <!-- Row 2: My Docs Grid -->
            <RowDefinition Height="Auto" /> <!-- Row 3: All Docs Header + PageSize 선택 -->
            <RowDefinition Height="*"    /> <!-- Row 4: All Docs DataGrid -->
            <RowDefinition Height="Auto" /> <!-- Row 5: 페이지 이동 컨트롤 -->
        </Grid.RowDefinitions>

        <!-- 1. Pending Approvals (결재 권한 사용자만 표시) -->
        <StackPanel Grid.Row="0" Visibility="{Binding IsApprover, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,20">
            <TextBlock Text="결재 대기 문서 (Pending Approvals)" 
                       FontSize="18" FontWeight="Bold" Foreground="#002c5f" Margin="0,0,0,10"/>
            <DataGrid ItemsSource="{Binding PendingApprovals}" AutoGenerateColumns="False" IsReadOnly="True"
                      BorderBrush="#e4dcd3" BorderThickness="1" Background="White"
                      MaxHeight="250">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding OpenPendingDetailCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="DocId" Binding="{Binding DocId}" Width="60"/>
                    <DataGridTextColumn Header="제목" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="작성자" Binding="{Binding WriterName}" Width="120"/>
                    <DataGridTextColumn Header="작성일" Binding="{Binding CreateDate, StringFormat=yyyy-MM-dd}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!-- 2. My Documents -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="내 문서 (My Documents)"
                       FontSize="18" FontWeight="Bold" Foreground="#002c5f"/>
            <Button Grid.Column="1" Content="선택 삭제"
                    Command="{Binding DeleteSelectedCommand}"
                    Padding="14,6" Background="#f44336" Foreground="White"
                    FontWeight="SemiBold" BorderThickness="0"/>
        </Grid>

        <DataGrid Grid.Row="2" x:Name="MyDraftsGrid"
                  ItemsSource="{Binding MyDrafts}" AutoGenerateColumns="False"
                  IsReadOnly="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  BorderBrush="#e4dcd3" BorderThickness="1" Background="White"
                  MaxHeight="200" SelectionMode="Single">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick"
                              Command="{Binding OpenDetailCommand}"
                              CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}"/>
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <!-- 체크박스: 승인완료 문서는 비활성 -->
                <DataGridTemplateColumn Width="40" CanUserSort="False" CanUserResize="False">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="선택" HorizontalAlignment="Center" FontSize="11"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      IsEnabled="{Binding CanSelect}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="DocId" Binding="{Binding DocId}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="제목" Binding="{Binding Title}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="결재자" Binding="{Binding CurrentApproverName}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="상태" Binding="{Binding StatusDisplay}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="작성일" Binding="{Binding CreateDate, StringFormat=yyyy-MM-dd}" Width="120" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 3. All Documents Header + PageSize 선택 -->
        <Grid Grid.Row="3" Margin="0,20,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="전체 문서 (All Documents)"
                       FontSize="18" FontWeight="Bold" Foreground="#002c5f"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="페이지당:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="#555" FontSize="13"/>
                <ComboBox ItemsSource="{Binding PageSizeOptions}"
                          SelectedItem="{Binding PageSize}"
                          Width="70" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 4. All Documents DataGrid -->
        <DataGrid Grid.Row="4" x:Name="AllDocsGrid"
                  ItemsSource="{Binding AllDocuments}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                  BorderBrush="#e4dcd3" BorderThickness="1" Background="White"
                  SelectionMode="Single"
                  Sorting="AllDocsGrid_Sorting">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick"
                              Command="{Binding OpenAllDocDetailCommand}"
                              CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=SelectedItem}"/>
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTextColumn Header="DocId"   Binding="{Binding DocId}"       Width="60"  SortMemberPath="DocId"       CanUserSort="True"/>
                <DataGridTextColumn Header="제목"    Binding="{Binding Title}"        Width="*"   SortMemberPath="Title"       CanUserSort="True"/>
                <DataGridTextColumn Header="작성자"  Binding="{Binding WriterName}"   Width="120" SortMemberPath="WriterName"  CanUserSort="True"/>
                <DataGridTextColumn Header="상태"    Binding="{Binding StatusDisplay}" Width="90" SortMemberPath="StatusDisplay" CanUserSort="True"/>
                <DataGridTextColumn Header="작성일"  Binding="{Binding CreateDate, StringFormat=yyyy-MM-dd}" Width="110" SortMemberPath="CreateDate" CanUserSort="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 5. 페이지 이동 + 검색 컨트롤 -->
        <Border Grid.Row="5" Margin="0,6,0,0" Padding="8,6"
                Background="#f5f5f5" BorderBrush="#e4dcd3" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- 페이지 정보 -->
                    <ColumnDefinition Width="*"/>     <!-- 검색 -->
                    <ColumnDefinition Width="Auto"/>  <!-- 이전/다음 -->
                </Grid.ColumnDefinitions>

                <!-- 페이지 정보 -->
                <TextBlock Grid.Column="0" Text="{Binding PageInfo}"
                           VerticalAlignment="Center" Foreground="#555" FontSize="13" Margin="0,0,16,0"/>

                <!-- 검색 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" Padding="6,4" Margin="0,0,6,0"
                             VerticalAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="검색"
                            Command="{Binding SearchCommand}"
                            Padding="12,4" FontWeight="SemiBold" BorderThickness="1"/>
                    <Button Content="초기화"
                            Padding="10,4" Margin="4,0,0,0" BorderThickness="1"
                            Click="SearchReset_Click"/>
                </StackPanel>

                <!-- 이전 / 다음 버튼 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="◀ 이전"
                            Command="{Binding PrevPageCommand}"
                            IsEnabled="{Binding CanGoPrev}"
                            Padding="14,5" Margin="0,0,6,0"
                            FontWeight="SemiBold" BorderThickness="1"/>
                    <Button Content="다음 ▶"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            Padding="14,5"
                            FontWeight="SemiBold" BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
