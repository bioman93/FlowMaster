<UserControl x:Class="FlowMaster.Desktop.Views.TestInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:FlowMaster.Desktop.Views"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:OutputButtonBrushConverter x:Key="OutputBtnBrush"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#002c5f"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style x:Key="PanelButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Row 0: Header -->
                <RowDefinition Height="Auto"/>  <!-- Row 1: 7:3 main area -->
                <RowDefinition Height="*"/>     <!-- Row 2: Checklist -->
                <RowDefinition Height="Auto" MaxHeight="210"/>  <!-- Row 3: 설명 (최대 210px, 체크리스트 침범 방지) -->
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0" Background="#002c5f" CornerRadius="8,8,0,0" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBox Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="18" FontWeight="Bold" Foreground="White"
                                 Background="Transparent" BorderThickness="0"
                                 CaretBrush="White"
                                 Margin="0,5,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="{Binding StatusColor}"
                            CornerRadius="4" Padding="12,6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── 7:3 Main Area ── -->
            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: 문서 유형 (7*) ── -->
                <Border Grid.Column="0" Background="White" Margin="0,0,5,0" Padding="10"
                        BorderBrush="#ddd" BorderThickness="1" CornerRadius="8">
                    <StackPanel>

                        <!-- 유형 / 세대 / 분사유형 / 버전 (가로 배치, 버전이 남은 공간 채움) -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- 고정 항목들 -->
                                <ColumnDefinition Width="Auto"/>  <!-- 버전 *: 레이블 -->
                                <ColumnDefinition Width="*"/>     <!-- 버전 TextBox -->
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="유형:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding TableType}" FontWeight="Bold" Foreground="#002c5f"
                                           VerticalAlignment="Center" MinWidth="35"/>
                                <TextBlock Text="세대:" Style="{StaticResource FieldLabel}" Margin="20,0,5,0"/>
                                <ComboBox Width="90" VerticalAlignment="Center"
                                          SelectedValue="{Binding GenType, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Content"
                                          IsEnabled="{Binding CanEdit}">
                                    <ComboBoxItem>1세대</ComboBoxItem>
                                    <ComboBoxItem>2세대</ComboBoxItem>
                                    <ComboBoxItem>3세대</ComboBoxItem>
                                </ComboBox>
                                <TextBlock Text="분사유형:" Style="{StaticResource FieldLabel}" Margin="20,0,5,0"/>
                                <ComboBox Width="80" VerticalAlignment="Center"
                                          SelectedValue="{Binding InjType, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Content"
                                          IsEnabled="{Binding CanSelectInjType}">
                                    <ComboBoxItem>MPI</ComboBoxItem>
                                    <ComboBoxItem>GDI</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="버전 *:" Style="{StaticResource FieldLabel}"
                                       Margin="20,0,5,0" Foreground="#c0392b" VerticalAlignment="Center"/>
                            <!-- 버전 TextBox + 자동완성 Popup (레이아웃 영향 없음) -->
                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <TextBox x:Name="VersionBox"
                                         Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CanEdit}" Padding="4,3"/>
                                <Popup IsOpen="{Binding IsVersionSuggestionsVisible, Mode=TwoWay}"
                                       PlacementTarget="{Binding ElementName=VersionBox}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       MinWidth="{Binding ActualWidth, ElementName=VersionBox}">
                                    <Border BorderBrush="#002c5f" BorderThickness="1" Background="White">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                                            <ItemsControl ItemsSource="{Binding VersionSuggestions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding ElementName=VersionBox, Path=DataContext.SelectVersionSuggestionCommand}"
                                                                CommandParameter="{Binding}"
                                                                BorderThickness="0" Background="Transparent"
                                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                Padding="6,4" Cursor="Hand">
                                                            <!-- TextBlock으로 감싸야 '_'가 액세스키로 처리되지 않음 -->
                                                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Grid>

                        <!-- 필드 그리드 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>  <!-- 담당자 -->
                                <RowDefinition Height="Auto"/> <!-- 평가결과 (조건부) -->
                                <RowDefinition Height="Auto"/>  <!-- 산출물경로 -->
                            </Grid.RowDefinitions>

                            <!-- 담당자 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="담당자:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WriterName}" VerticalAlignment="Center"/>

                            <!-- 평가결과 (모든 메인항목 채워졌을 때) -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="평가결과:" Style="{StaticResource FieldLabel}"
                                       Margin="0,6,5,6"
                                       Visibility="{Binding ShowOverallEvaluation, Converter={StaticResource BoolToVis}}"/>
                            <Border Grid.Row="1" Grid.Column="1" Margin="0,6,0,6"
                                    Background="{Binding OverallEvaluationColor}"
                                    CornerRadius="4" Padding="12,4" HorizontalAlignment="Left"
                                    Visibility="{Binding ShowOverallEvaluation, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding OverallEvaluationCode}"
                                           Foreground="White" FontWeight="Bold" FontSize="14"/>
                            </Border>

                            <!-- 산출물경로: BA1/BA2는 버튼 선택, 그 외 유형은 TextBox -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="산출물:" Style="{StaticResource FieldLabel}"/>
                            <Grid Grid.Row="2" Grid.Column="1" Margin="0,2,0,2">
                                <!-- BA1 버튼 (4개) -->
                                <WrapPanel Visibility="{Binding IsBA1Type, Converter={StaticResource BoolToVis}}">
                                    <Button Content="Baseline 문서" Click="DocumentOutputButton_Click"
                                            Padding="6,3" Margin="0,0,4,2" FontSize="11" Cursor="Hand"
                                            BorderBrush="#002c5f" BorderThickness="1">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Background>
                                        <Button.Foreground>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}" ConverterParameter="fg">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Foreground>
                                    </Button>
                                    <Button Content="SW 배포 문서" Click="DocumentOutputButton_Click"
                                            Padding="6,3" Margin="0,0,4,2" FontSize="11" Cursor="Hand"
                                            BorderBrush="#002c5f" BorderThickness="1">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Background>
                                        <Button.Foreground>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}" ConverterParameter="fg">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Foreground>
                                    </Button>
                                    <Button Content="All-in-one 문서" Click="DocumentOutputButton_Click"
                                            Padding="6,3" Margin="0,0,4,2" FontSize="11" Cursor="Hand"
                                            BorderBrush="#002c5f" BorderThickness="1">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Background>
                                        <Button.Foreground>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}" ConverterParameter="fg">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Foreground>
                                    </Button>
                                    <Button Content="LCR 심의회 회의록" Click="DocumentOutputButton_Click"
                                            Padding="6,3" Margin="0,0,4,2" FontSize="11" Cursor="Hand"
                                            BorderBrush="#002c5f" BorderThickness="1">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Background>
                                        <Button.Foreground>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}" ConverterParameter="fg">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Foreground>
                                    </Button>
                                </WrapPanel>

                                <!-- BA2 버튼 (5개) -->
                                <WrapPanel Visibility="{Binding IsBA2Type, Converter={StaticResource BoolToVis}}">
                                    <Button Content="Baseline 문서" Click="DocumentOutputButton_Click"
                                            Padding="6,3" Margin="0,0,4,2" FontSize="11" Cursor="Hand"
                                            BorderBrush="#002c5f" BorderThickness="1">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Background>
                                        <Button.Foreground>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}" ConverterParameter="fg">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Foreground>
                                    </Button>
                                    <Button Content="SW 배포 문서" Click="DocumentOutputButton_Click"
                                            Padding="6,3" Margin="0,0,4,2" FontSize="11" Cursor="Hand"
                                            BorderBrush="#002c5f" BorderThickness="1">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Background>
                                        <Button.Foreground>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}" ConverterParameter="fg">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Foreground>
                                    </Button>
                                    <Button Content="All-in-one 문서" Click="DocumentOutputButton_Click"
                                            Padding="6,3" Margin="0,0,4,2" FontSize="11" Cursor="Hand"
                                            BorderBrush="#002c5f" BorderThickness="1">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Background>
                                        <Button.Foreground>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}" ConverterParameter="fg">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Foreground>
                                    </Button>
                                    <Button Content="SW 빌드 체크 시트" Click="DocumentOutputButton_Click"
                                            Padding="6,3" Margin="0,0,4,2" FontSize="11" Cursor="Hand"
                                            BorderBrush="#002c5f" BorderThickness="1">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Background>
                                        <Button.Foreground>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}" ConverterParameter="fg">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Foreground>
                                    </Button>
                                    <Button Content="LCR 심의회 회의록" Click="DocumentOutputButton_Click"
                                            Padding="6,3" Margin="0,0,4,2" FontSize="11" Cursor="Hand"
                                            BorderBrush="#002c5f" BorderThickness="1">
                                        <Button.Background>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Background>
                                        <Button.Foreground>
                                            <MultiBinding Converter="{StaticResource OutputBtnBrush}" ConverterParameter="fg">
                                                <Binding Path="OutputPath"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                            </MultiBinding>
                                        </Button.Foreground>
                                    </Button>
                                </WrapPanel>

                                <!-- 기타 유형: TextBox -->
                                <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CanEdit}" Padding="4,3">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBA1Type}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsBA2Type}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </Grid>

                        <!-- 참여자 섹션 -->
                        <StackPanel Margin="0,6,0,0">
                            <!-- 참여자 헤더 + 검색 입력 (같은 행) -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="참여자" Style="{StaticResource SectionHeader}"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <Grid Grid.Column="1" IsEnabled="{Binding CanEdit}">
                                    <TextBox Text="{Binding ParticipantSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,4">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                                    <VisualBrush.Visual>
                                                                        <TextBlock Text="이름으로 참여자 검색..." Foreground="#aaa" Margin="8,4"/>
                                                                    </VisualBrush.Visual>
                                                                </VisualBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <ListBox ItemsSource="{Binding ParticipantSearchResults}"
                                             Visibility="{Binding IsParticipantSearchVisible, Converter={StaticResource BoolToVis}}"
                                             MaxHeight="160" VerticalAlignment="Top" Margin="0,30,0,0"
                                             Panel.ZIndex="10"
                                             BorderBrush="#002c5f" BorderThickness="1">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Name}"
                                                        Command="{Binding DataContext.AddParticipantCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        BorderThickness="0" Background="Transparent"
                                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                        Padding="6,4" Cursor="Hand"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Grid>

                            <!-- 참여자 Chip 목록 -->
                            <ItemsControl ItemsSource="{Binding Participants}" Margin="0,4,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#e8edf4" CornerRadius="4" Margin="3,3,0,0" Padding="8,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"/>
                                                <Button Content="×" Margin="4,0,0,0" Padding="2,0"
                                                        BorderThickness="0" Background="Transparent" FontSize="14"
                                                        Foreground="#666" Cursor="Hand"
                                                        Command="{Binding DataContext.RemoveParticipantCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding DataContext.CanEdit,
                                                            RelativeSource={RelativeSource AncestorType=UserControl},
                                                            Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ── Right: 결재 정보 (3*) ── -->
                <Border Grid.Column="1" Background="White" Margin="5,0,0,0" Padding="10"
                        BorderBrush="#ddd" BorderThickness="1" CornerRadius="8">
                    <StackPanel>

                        <!-- 결재자 -->
                        <TextBlock Text="결재자 *:" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"
                                   Foreground="#c0392b"/>
                        <ComboBox ItemsSource="{Binding AvailableApprovers}"
                                  SelectedItem="{Binding SelectedApprover}"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding CanEdit}"
                                  Margin="0,0,0,14"/>

                        <!-- 결재 코멘트 입력 (결재자가 승인/반려 전) -->
                        <StackPanel Visibility="{Binding ShowApproverInput}" Margin="0,0,0,14">
                            <TextBlock Text="결재 코멘트:" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ApproverComment, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="80" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>

                        <!-- 결재 코멘트 표시 (승인완료/반려 후 읽기전용) -->
                        <Border Background="#fff8e8" Padding="10"
                                BorderBrush="#ffe0a0" BorderThickness="1" CornerRadius="4"
                                Margin="0,0,0,14"
                                Visibility="{Binding ShowApproverComment}">
                            <StackPanel>
                                <TextBlock Text="결재 코멘트" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ApproverComment}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- 결재 일시 (승인완료 또는 반려) -->
                        <StackPanel Visibility="{Binding ShowApprovalDate, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="결재 일시" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ApprovalDate}" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- 액션 버튼 (모두 같은 행: 삭제 / 수정(임시저장) / 결재요청취소 / 결재요청 / 승인 / 반려) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="삭제" Command="{Binding DeleteCommand}"
                                    Style="{StaticResource PanelButton}" Background="#f44336" Foreground="White"
                                    Visibility="{Binding CanDelete}"/>
                            <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}"
                                    Visibility="{Binding CanSave}"
                                    Style="{StaticResource PanelButton}"
                                    Background="#4CAF50" Foreground="White"/>
                            <Button Content="결재 요청 취소" Command="{Binding CancelSubmitCommand}"
                                    Visibility="{Binding CanCancel}"
                                    Style="{StaticResource PanelButton}"
                                    Background="#f44336" Foreground="White"/>
                            <Button Content="결재 요청" Command="{Binding SubmitCommand}"
                                    Visibility="{Binding CanSubmit}"
                                    IsEnabled="{Binding CanRequestApproval}"
                                    Style="{StaticResource PanelButton}"
                                    Background="#002c5f" Foreground="White"/>
                            <Button Content="승인" Command="{Binding ApproveCommand}"
                                    Visibility="{Binding CanApprove}"
                                    Style="{StaticResource PanelButton}"
                                    Background="#2196F3" Foreground="White"/>
                            <Button Content="반려" Command="{Binding RejectCommand}"
                                    Visibility="{Binding CanApprove}"
                                    Style="{StaticResource PanelButton}"
                                    Background="#f44336" Foreground="White"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Checklist DataGrid ── -->
            <Border Grid.Row="2" Background="White" Margin="0,6,0,0"
                    BorderBrush="#ddd" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#f8f8f8" Padding="10" CornerRadius="8,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="테스트 결과 체크리스트" Style="{StaticResource SectionHeader}" Margin="0"/>
                            <TextBlock Text="{Binding ChecklistItemCount, StringFormat=' - {0}항목'}"
                                       Foreground="#888" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ChecklistItems}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" CanUserSortColumns="False"
                              EnableRowVirtualization="False"
                              IsReadOnly="{Binding IsReadOnly}"
                              BeginningEdit="Checklist_BeginningEdit"
                              PreparingCellForEdit="Checklist_PreparingCellForEdit">
                        <!-- 셀 클릭 한 번에 편집 진입 (GotFocus: 행 선택 완료 후 BeginEdit 호출) -->
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <EventSetter Event="GotFocus"
                                             Handler="ChecklistCell_GotFocus"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <!-- 헤더 행 (IsHeader=true): 굵은 글씨 + 배경색 -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                        <Setter Property="Background" Value="#dde4f0"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#002c5f"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <!-- No. -->
                            <DataGridTextColumn Header="No." Binding="{Binding RowNo}" Width="60" IsReadOnly="True"/>

                            <!-- 확인항목: 긴 텍스트 줄바꿈 + \n 개행 지원 -->
                            <DataGridTemplateColumn Header="확인항목" Width="*" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CheckItem}" TextWrapping="Wrap"
                                                   Padding="4,3" VerticalAlignment="Top"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 산출물: 줄바꿈 지원 TextBox -->
                            <DataGridTemplateColumn Header="산출물" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding OutputContent}" TextWrapping="Wrap"
                                                   Padding="4,3" VerticalAlignment="Top"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding OutputContent, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap" AcceptsReturn="True"
                                                 MinHeight="36" MaxHeight="150"
                                                 VerticalScrollBarVisibility="Auto" Padding="4,3"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- 평가: ComboBox -->
                            <DataGridComboBoxColumn Header="평가" Width="80">
                                <DataGridComboBoxColumn.ItemsSource>
                                    <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                        <sys:String>+</sys:String>
                                        <sys:String>(+)</sys:String>
                                        <sys:String>(-)</sys:String>
                                        <sys:String>-</sys:String>
                                        <sys:String>nb</sys:String>
                                    </x:Array>
                                </DataGridComboBoxColumn.ItemsSource>
                                <DataGridComboBoxColumn.SelectedItemBinding>
                                    <Binding Path="EvaluationCode"/>
                                </DataGridComboBoxColumn.SelectedItemBinding>
                            </DataGridComboBoxColumn>

                            <!-- 비고: 줄바꿈 지원 -->
                            <DataGridTemplateColumn Header="비고" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Remarks}" TextWrapping="Wrap"
                                                   Padding="4,3" VerticalAlignment="Top"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap" AcceptsReturn="True"
                                                 MinHeight="36" MaxHeight="150"
                                                 VerticalScrollBarVisibility="Auto" Padding="4,3"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── 설명 (BA2만, 체크리스트 아래) ── -->
            <Border Grid.Row="3" Background="White" Margin="0,6,0,0" Padding="10,8"
                    BorderBrush="#ddd" BorderThickness="1" CornerRadius="8"
                    Visibility="{Binding ShowDescription}">
                <StackPanel>
                    <TextBlock Text="설명:" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    <!-- WebBrowser: HTML WYSIWYG 편집 (contentEditable). 고정 높이 필요 (HwndHost 특성) -->
                    <Border BorderBrush="#ccc" BorderThickness="1" Height="160">
                        <WebBrowser x:Name="DescriptionBrowser"
                                    LoadCompleted="DescriptionBrowser_LoadCompleted"/>
                    </Border>
                </StackPanel>
            </Border>

    </Grid>
</UserControl>
