<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- ApprovalSystem API 서버 URL (VehicleReservation이 5001을 사용하므로 5002 사용) -->
    <add key="ApprovalApi:BaseUrl" value="http://localhost:5002/api" />
    <!-- AD Emulator 서버 URL -->
    <add key="Emulator:BaseUrl" value="http://localhost:3900" />
    <!-- 공유 SQLite DB 경로 (emulator.db). 비워두면 로컬 flowmaster_test.db 사용 -->
    <add key="FlowMaster:DbPath" value="" />
    <!-- 실제 AD 역할 그룹 매핑 (Emulator 미사용 시 적용, 쉼표로 구분) -->
    <!-- 실제 AD 그룹명과 일치하도록 변경하세요 -->
    <add key="AD:AdminGroups"    value="GRP_Executives" />
    <add key="AD:ApproverGroups" value="GRP_Managers,GRP_Approvers" />
  </appSettings>
</configuration>
